# Copier ce fichier en .env et adapter les mots de passe si besoin.
# Usage: docker compose --env-file .env up -d --build

MYSQL_ROOT_PASSWORD=backup_root
MYSQL_DATABASE=backupcontent
MYSQL_USER=backup
MYSQL_PASSWORD=backup

# Optionnel — parsing IA via Ollama sur la machine hôte (Windows/Mac: host.docker.internal)
OLLAMA_HOST=http://host.docker.internal:11434
USE_OPENAI=false
DOCUMENT_AI_USE_AI=false

# Dossier Excel fournisseurs sur la machine hôte → monté dans le conteneur api
# Ex. Windows: F:/EuroBricoMigration/product
# Ex. Linux:   /opt/eurobrico/product
EXCEL_PRODUCT_HOST_PATH=c:\jaafar\produits

# Chemin vu par l'API dans le conteneur (ne pas mettre un chemin Windows ici)
EXCEL_PRODUCT_CONTAINER_PATH=/data/eurobrico-product
