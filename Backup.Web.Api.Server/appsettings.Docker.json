{
  "UseHttpsRedirection": false,
  "Database": {
    "ApplyMigrationsOnStartup": true,
    "ServerVersion": "8.4.0-mysql"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=mysql;Port=3306;Database=backupcontent;User=backup;Password=backup;Persist Security Info=False;Connect Timeout=300"
  },
  "AppSettings": {
    "hostdev": "http://localhost:8080",
    "hostprod": "http://localhost:8080"
  },
  "PythonExtractor": {
    "Enabled": true,
    "Url": "http://python-extractor:8000"
  },
  "Ollama": {
    "Enabled": false,
    "Host": "http://host.docker.internal:11434"
  },
  "PdfToText": {
    "ExecutablePath": "",
    "Args": "-layout -enc UTF-8",
    "TimeoutSeconds": 30
  },
  "Ocr": {
    "TessdataPath": "/usr/share/tesseract-ocr/5/tessdata",
    "Language": "fra+eng",
    "Dpi": 500
  },
  "ErpPricing": {
    "BaseUrl": "http://eurobrico.ddns.net:15021/ServiceMM.svc/getProductStockByReference",
    "ReferenceBrandPrefixes": [ "Benman", "FF-Group", "FF Group", "FFGroup" ]
  },
  "ErpSync": {
    "Enabled": true,
    "BaseUrl": "http://eurobrico.ddns.net:15021/ServiceMM.svc",
    "ImageBaseUrl": "http://eurobrico.ddns.net:15022",
    "CustomerId": "0",
    "CronDayOfWeek": 5,
    "CronHour": 18,
    "CronMinute": 0,
    "BatchSize": 50,
    "TimeoutSeconds": 30,
    "RetryCount": 3,
    "SyncMode": "FullCatalog",
    "ScheduledSyncMode": "FullCatalog",
    "ExcelProductPath": "/data/eurobrico-product"
  },
  "StoreChat": {
    "BrandName": "EuroBrico",
    "ReturnBaseUrl": "http://localhost:4200",
    "MaxProductResults": 5,
    "InitialProductResults": 3,
    "ChatHistoryLimit": 12
  },
  "AISettings": {
    "Provider": "Ollama",
    "SystemPrompt": "Tu es l'assistant magasin EuroBrico. Réponds en français, 2 à 4 phrases max. Le catalogue est multilingue (FR/NL/EN). Ne propose QUE les produits listés dans le catalogue fourni. Si une marque est demandée, ne parle QUE de cette marque et des produits listés. N'invente aucune gamme (ex. « ciments Knauf ») absente de la liste. Si le catalogue est vide pour la demande, dis-le clairement. Si des produits sont listés, invite à choisir dans l'interface (quantité, panier, devis). Une seule question de clarification UNIQUEMENT si aucun produit n'est listé et que la demande est vraiment vague.",
    "Ollama": {
      "ApiKey": "ollama",
      "Model": "qwen2.5:14b",
      "Endpoint": "http://host.docker.internal:11434",
      "EmbeddingModel": "nomic-embed-text"
    }
  },
  "Stripe": {
    "SecretKey": "",
    "PublishableKey": "",
    "WebhookSecret": ""
  }
}
